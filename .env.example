# ============================================================
# IWA-SPA – Intentionally Insecure Online Pharmacy
# Environment Variables (non-secret defaults for demo only)
# ============================================================

# Backend
PORT=4000
NODE_ENV=development

# INTENTIONAL: hard-coded JWT secret for demo/training
JWT_SECRET=insecure-jwt-secret-do-not-use-in-production

# INTENTIONAL: DB path baked in for simplicity
DB_PATH=./database/pharmacy.db

# Frontend (Vite)
VITE_API_URL=http://localhost:4000
